rules_version = '2';
// Firestore security rules – Landline
// Development mode: authenticated users can read/write their own document in users collection.
// Deploy: firebase deploy --only firestore:rules (requires firebase.json and Firebase CLI)

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Beta signup collection for waitlist
    match /betaSignups/{docId} {
      // Allow create if email is valid format
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.matches('^[\\w\\-\\.]+@([\\w\\-]+\\.)+[\\w\\-]{2,4}$')
                    && request.resource.data.timestamp is timestamp;

      // Allow read only for specific admin user
      allow read: if request.auth != null && request.auth.token.email == 'admin@landline.app';

      // No update or delete allowed
      allow update, delete: if false;
    }
  }
}
