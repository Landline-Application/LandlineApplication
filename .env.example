# Path to google-services.json (required for Android/Firebase)
# Absolute or relative path from project root
GOOGLE_SERVICES_JSON=/path/to/google-services.json

# Google OAuth 2.0 web client ID (required for Google Sign-In)
# Obtain from Firebase Console → Authentication → Sign-in method → Google
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
