# Path to google-services.json (required for Android/Firebase)
# Absolute or relative path from project root
GOOGLE_SERVICES_JSON=/path/to/google-services.json

# Google OAuth 2.0 web client ID (required for Google Sign-In)
# Obtain from Firebase Console → Authentication → Sign-in method → Google
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Keystore credentials (required for Gradle local builds)
# Used by scripts/build-production-gradle.sh
KEYSTORE_FILE=landline-release.keystore
KEYSTORE_ALIAS=landline
KEYSTORE_STORE_PASSWORD=your-store-password
KEYSTORE_KEY_PASSWORD=your-key-password

# EAS project ID (required for Expo Application Services builds/submissions)
# Obtain from Expo dashboard → project settings
EAS_PROJECT_ID=9054e1e3-4810-4cc2a8

# Expo organization owner slug (required for EAS submissions)
# Obtain from Expo dashboard → organization settings
EXPO_OWNER=landline-application

# Firebase Web API Key (required for scripts/create-admin-user.js and scripts/test-export.js)
# Obtain from Firebase Console → Project Settings → General → Web API Key
FIREBASE_API_KEY=your-firebase-web-api-key
