<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 
        Note: BIND_NOTIFICATION_LISTENER_SERVICE permission and service are now 
        handled by the unified LandlineNotificationListenerService in notification-api-manager module.
        This module now only provides the AutoReplyManager API and TestNotificationHelper.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <application>
        <receiver
            android:name=".TestNotificationHelper$ReplyReceiver"
            android:exported="false" />
    </application>
</manifest>
